# 기본: 인증 없이 로컬 MongoDB (127.0.0.1:27017, DB 이름 todo)
# 추가 설정 없이도 동작합니다.

# 선택: DB 이름
# MONGODB_DB=todo

# 선택: 호스트/포트 (기본 127.0.0.1 / 27017)
# MONGODB_HOST=127.0.0.1
# MONGODB_PORT=27017

# 로컬에서 사용자/비밀번호를 쓰는 경우
# MONGODB_USER=
# MONGODB_PASSWORD=

# Atlas 등 전체 URI (MONGO_URI 또는 MONGODB_URI 둘 다 지원)
# MONGO_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/todo?retryWrites=true&w=majority

# HTTP 서버 포트 (기본 5001, macOS 5000은 AirPlay 등과 충돌 가능)
# PORT=5001
